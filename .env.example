# Copy this file to .env and fill in real values before running in production.
# Do NOT commit your real .env file — it is already ignored via .gitignore.

# Port Hostinger (or any host) assigns at runtime. Falls back to 3000 locally.
PORT=3000

# ---- SMTP (contact form delivery) ----
# Works with any SMTP provider: Hostinger email, Gmail (app password), SendGrid,
# Postmark, Mailgun, etc. Fill in the host/port/user/pass your provider gives you.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Address the "From" header will use (often must match SMTP_USER's domain)
SMTP_FROM="Funnele Website <no-reply@funnele.com>"

# Where contact form submissions get delivered
CONTACT_TO_EMAIL=abhijeet@funnele.com

<%- include('partials/head') %>
<%- include('partials/nav') %>

<main id="top">

  <section class="hero">
    <div class="hero-glow"></div>
    <svg class="hero-graphic" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
      <g stroke="#E43525" stroke-width="1.4" fill="none" opacity="0.7">
        <line class="funnel-line" x1="60" y1="60" x2="200" y2="150"/>
        <line class="funnel-line" x1="340" y1="90" x2="200" y2="150"/>
        <line class="funnel-line" x1="200" y1="150" x2="140" y2="260"/>
        <line class="funnel-line" x1="200" y1="150" x2="270" y2="260"/>
        <line class="funnel-line" x1="140" y1="260" x2="200" y2="340"/>
        <line class="funnel-line" x1="270" y1="260" x2="200" y2="340"/>
      </g>
      <circle class="funnel-node" cx="60" cy="60" r="7" fill="#E43525"/>
      <circle class="funnel-node" cx="340" cy="90" r="6" fill="#E43525" opacity="0.8"/>
      <circle class="funnel-node" cx="200" cy="150" r="9" fill="#E43525"/>
      <circle class="funnel-node" cx="140" cy="260" r="6" fill="#E43525" opacity="0.85"/>
      <circle class="funnel-node" cx="270" cy="260" r="6" fill="#E43525" opacity="0.85"/>
      <circle class="funnel-node" cx="200" cy="340" r="10" fill="#E43525"/>
    </svg>
    <div class="wrap hero-inner">
      <p class="eyebrow">White-label execution partner</p>
      <h1>You don't need another vendor.<br>You need a <span class="accent">Funnele</span>.</h1>
      <p class="lead">Meta Ads, Google Ads, SEO and web development, delivered under your brand. Your clients see your name. You get senior-level execution without the senior-level headcount.</p>
      <div class="btn-row">
        <a href="/contact" class="btn btn-primary">Start a Partnership →</a>
        <a href="/services" class="btn btn-secondary">See What We Execute</a>
      </div>
    </div>
  </section>

  <div class="trust-strip">
    <div class="wrap trust-inner">
      <div class="trust-item"><svg class="icon"><use href="#icon-shield"/></svg>No client poaching, ever — written into every agreement</div>
      <div class="trust-item"><svg class="icon"><use href="#icon-doc"/></svg>Zero branding on deliverables, dashboards or invoices</div>
      <div class="trust-item"><svg class="icon"><use href="#icon-check"/></svg>NDA and non-compete signed before any account access</div>
    </div>
  </div>

  <section id="capabilities">
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">What we execute</p>
        <h2>One partner. Four disciplines you can resell.</h2>
        <p>Hand off the channels that stretch your team thin. Keep the strategy and the client relationship in-house.</p>
      </div>

      <div class="capabilities-layout">
        <div class="cap-grid">
          <a href="/services/meta-ads" class="cap-card reveal">
            <div class="icon-badge"><svg class="icon"><use href="#icon-meta"/></svg></div>
            <h3>Meta Ads</h3>
            <p>Full-funnel campaign management for ecommerce and DTC brands.</p>
            <div class="deliverables"><span>Campaign builds</span><span>Creative testing</span></div>
          </a>
          <a href="/services/google-ads" class="cap-card reveal">
            <div class="icon-badge"><svg class="icon"><use href="#icon-google"/></svg></div>
            <h3>Google Ads</h3>
            <p>Search, Shopping and Performance Max, built around margin.</p>
            <div class="deliverables"><span>Account structure</span><span>Bid strategy</span></div>
          </a>
          <a href="/services/seo" class="cap-card reveal">
            <div class="icon-badge"><svg class="icon"><use href="#icon-seo"/></svg></div>
            <h3>SEO</h3>
            <p>Technical audits, on-page and content operations.</p>
            <div class="deliverables"><span>Technical audits</span><span>Content ops</span></div>
          </a>
          <a href="/services/web-development" class="cap-card reveal">
            <div class="icon-badge"><svg class="icon"><use href="#icon-web"/></svg></div>
            <h3>Web Development</h3>
            <p>Shopify builds, landing pages and CRO iteration.</p>
            <div class="deliverables"><span>Shopify builds</span><span>CRO</span></div>
          </a>
        </div>

        <div class="manifest reveal">
          <div class="manifest-head"><span>Partnership manifest</span><span>Live</span></div>
          <div class="manifest-row"><span class="idx">01</span><span class="label">Meta Ads<small>Prospecting &amp; retargeting</small></span><span class="tag">Ecommerce</span></div>
          <div class="manifest-row"><span class="idx">02</span><span class="label">Google Ads<small>Search &amp; Shopping</small></span><span class="tag">Lead Gen</span></div>
          <div class="manifest-row"><span class="idx">03</span><span class="label">SEO<small>Technical &amp; content</small></span><span class="tag">Organic</span></div>
          <div class="manifest-row"><span class="idx">04</span><span class="label">Web Dev<small>Shopify &amp; CRO</small></span><span class="tag">Web</span></div>
        </div>
      </div>
    </div>
  </section>

  <section id="why">
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">Why agencies partner with Funnele</p>
        <h2>Built specifically to sit behind your brand.</h2>
      </div>
      <div class="why-grid">
        <div class="why-card reveal">
          <div class="icon-badge"><svg class="icon"><use href="#icon-doc"/></svg></div>
          <div class="stat">0</div>
          <h3>Client-facing footprint</h3>
          <p>No Funnele branding on dashboards, decks or invoices sent to your client.</p>
        </div>
        <div class="why-card reveal">
          <div class="icon-badge"><svg class="icon"><use href="#icon-user"/></svg></div>
          <div class="stat">1</div>
          <h3>Point of contact</h3>
          <p>One dedicated account lead on our side. Scope and reporting never get lost.</p>
        </div>
        <div class="why-card reveal">
          <div class="icon-badge"><svg class="icon"><use href="#icon-flag"/></svg></div>
          <div class="stat">US</div>
          <h3>Ecommerce specialization</h3>
          <p>Primary focus on US-based ecommerce and DTC accounts.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="industries">
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">Who we're built for</p>
        <h2>Account types we're set up to run.</h2>
        <p>Our specialization is US ecommerce and DTC — these are the account shapes we're built to execute against.</p>
      </div>
      <div class="industries-grid">
        <% industries.forEach(function(ind) { %>
        <div class="industry-card reveal">
          <div class="icon-badge"><svg class="icon"><use href="#<%= ind.icon %>"/></svg></div>
          <h3><%= ind.title %></h3>
          <p><%= ind.desc %></p>
        </div>
        <% }) %>
      </div>
    </div>
  </section>

  <section id="reporting">
    <div class="wrap">
      <div class="reporting-layout">
        <div class="section-head reveal" style="margin-bottom:0;">
          <p class="eyebrow">What your client sees</p>
          <h2>Reporting that looks like it came from your team.</h2>
          <p>Every dashboard, chart and report is formatted under your brand — not a Funnele-labeled export forwarded along.</p>
          <ul class="reporting-points">
            <li><svg class="icon icon-sm"><use href="#icon-check"/></svg>Your logo, your domain, your color scheme</li>
            <li><svg class="icon icon-sm"><use href="#icon-check"/></svg>Delivered on a fixed weekly or monthly cadence</li>
            <li><svg class="icon icon-sm"><use href="#icon-check"/></svg>You review before anything reaches your client</li>
          </ul>
        </div>
        <%- include('partials/dashboard-mock', { metrics: homeMetrics, slug: 'overview' }) %>
      </div>
    </div>
  </section>

  <section id="faq">
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">Common questions</p>
        <h2>Before you reach out.</h2>
      </div>
      <%- include('partials/faq', { faqs: homeFaqs, idPrefix: 'home' }) %>
    </div>
  </section>

  <section class="cta-band" style="border-bottom:none;">
    <div class="wrap">
      <h2>Tell us what's stretching your team thin.</h2>
      <p>One call to walk through your accounts, your channels, and whether Funnele is the right fit.</p>
      <div class="btn-row"><a href="/contact" class="btn btn-primary">Start a Partnership →</a></div>
    </div>
  </section>

</main>

<%- include('partials/footer') %>
